 144          /********************************************************************************
 145           ** \brief   GPIO_IntSelect
 146           **      ŃˇÔńIOÖĐ¶ĎµÄ´Ą·˘·˝Ę˝
 147           ** \param [in] Port  Łş GPIO0ˇ˘GPIO1ˇ˘GPIO2ˇ˘GPIO3 
 148           **         PinMsk: GPIO_PIN_0 ~ GPIO_PIN_7
 149           ** \param [in] Pulse Łş 
 150           **                   (0):GPIO_INT_NONE     
 151           **                   (1):GPIO_INT_RISING     
 152           **                   (2):GPIO_INT_FALLING      
 153           **                   (3):GPIO_INT_BOTH_EDGE          
 154           ** \return  none
 155           ** \note
 156           **  (1)P0µÄPinMSKĘäČëÖµ·¶Î§ŁşGPIO_PIN_4 ~ GPIO_PIN_5
 157           **  (2)P1µÄPinMSKĘäČëÖµ·¶Î§ŁşGPIO_PIN_3 ~ GPIO_PIN_7
 158           **  (3)P2µÄPinMSKĘäČëÖµ·¶Î§ŁşGPIO_PIN_1 ~ GPIO_PIN_6
 159           **  (4)P3µÄPinMSKĘäČëÖµ·¶Î§ŁşGPIO_PIN_0 ~ GPIO_PIN_2ˇ˘GPIO_PIN_5ˇ˘GPIO_PIN_6
 160           ******************************************************************************/
 161          void GPIO_IntSelect(uint8_t Port,uint8_t PinMsk,uint8_t Pulse)
 162          {
 163   1        
 164   1        switch(Port)
 165   1        {
 166   2          case GPIO0:   
 167   2                if(PinMsk == GPIO_PIN_4)
 168   2                {
 169   3                  P0INT1 &= ~(PORT_P0INT1_P04INTEG_Msk) ;
 170   3                  P0INT1 |= Pulse ;
 171   3                }
 172   2                else
 173   2                {
 174   3                  P0INT1 &= ~(PORT_P0INT1_P05INTEG_Msk) ;
 175   3                  P0INT1 |= Pulse << PORT_P0INT1_P05INTEG_Pos;
 176   3                }
 177   2          break;
C51 COMPILER V9.60.7.0   GPIO                                                              04/24/2026 14:09:26 PAGE 4   

 178   2          case GPIO1:
 179   2                if(PinMsk <= GPIO_PIN_3)
 180   2                {
 181   3                  P1INT0 &= ~(3<< (2 * PinMsk)) ;
 182   3                  P1INT0 |= Pulse << (PinMsk * 2);
 183   3                }
 184   2                else
 185   2                {
 186   3                  P1INT1 &= ~(3<< (2*(PinMsk - GPIO_PIN_4))) ;
 187   3                  P1INT1 |= Pulse << ((PinMsk - GPIO_PIN_4) * 2);
 188   3                }
 189   2          break;
 190   2          case GPIO2:
 191   2                if(PinMsk <= GPIO_PIN_3)
 192   2                {
 193   3                  P2INT0 &= ~(3<< (2 * PinMsk)) ;
 194   3                  P2INT0 |= Pulse << (PinMsk * 2);
 195   3                }
 196   2                else
 197   2                {
 198   3                  P2INT1 &= ~(3<< (2*(PinMsk - GPIO_PIN_4))) ;
 199   3                  P2INT1 |= Pulse << ((PinMsk - GPIO_PIN_4) * 2);
 200   3                }
 201   2          break;
 202   2          case GPIO3:
 203   2                if(PinMsk <= GPIO_PIN_3)
 204   2                {
 205   3                  P3INT0 &= ~(3<< (2 * PinMsk)) ;
 206   3                  P3INT0 |= Pulse << (PinMsk * 2);
 207   3                }
 208   2                else
 209   2                {
 210   3                  P3INT1 &= ~(3<< (2*(PinMsk - GPIO_PIN_4))) ;
 211   3                  P3INT1 |= Pulse << ((PinMsk - GPIO_PIN_4) * 2);
 212   3                }
 213   2          break;
