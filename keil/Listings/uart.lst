  59          /******************************************************************************
  60           ** \brief   UART_Config
  61           ** \param [in] 
  62           **             
  63           ** \return  none
  64           ** \note  
  65           ******************************************************************************/
  66           /******************************************************************************
  67           Fsys=8MHz                             Fsys=16MHz
  68           Baudrate   SPBRG     误差(%)          Baudrate   SPBRG     误差(%)
  69             2400      207      0.16                -        -         -
  70             9600      51       0.16              9600       103       0.16
  71             10417     47        0                10417      95        0
  72             19200     25       0.16              19200      51        0.16
  73           ******************************************************************************/
  74          void UART_Config(void)
  75          {
  76   1        
  77   1        USSEL = 0x00;     
  78   1        GPIO_ENABLE_OUTPUT(P2TRIS, GPIO_PIN_5);   //设置TXD口
  79   1        //GPIO_ENABLE_INPUT(P2TRIS, GPIO_PIN_6);    //设置RXD口
  80   1          
  81   1        SPBRG = 103;      //设置波特率为9600 bps，误差0.16%
  82   1        TXSTA &= 0xA7;    //异步模式,数据直接发送 ,8位发送
  83   1      
  84   1        RCSTA |= 0x90;    //允许串口操作,使能接收 
  85   1                            
  86   1        RCSTA &= 0xBF;    //8位接收
  87   1        TXSTA |= 0x20;    //使能发送
  88   1        
  89   1        IRQ_ALL_ENABLE();
  90   1      }
