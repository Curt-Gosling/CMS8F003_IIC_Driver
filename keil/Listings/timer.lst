  58          /******************************************************************************
  59          ** \brief  TMR1_Config
  60          ** \param [in] 
  61          **              
  62          ** \return  none
  63          ** \note  
  64          ******************************************************************************/
  65          /*-------------------------------------------
  66          备注：   定时时间计算方法
  67                    定时时间T = {1/[(Fosc)*预分频比)]}*(65535-[TMR1H:TMR1L])
  68                    本程序计算示例：
  69                    T = {1/[(16)*8]}*(65536 - 63536)
  70                      = 1000 us
  71          -------------------------------------------*/
  72          void TMR1_Config(void)
  73          {
  74   1        /*
  75   1        (1)设置Timer的运行模式
  76   1        */  
  77   1        T1CON = 0x30;       //使用内部时钟源Fosc，预分频比为1:8      
  78   1        /*                  
  79   1        (2)设置Timer周期     
  80   1        */                  
  81   1        TMR1L = 0x30;       //赋初值
  82   1        TMR1H = 0xF8; 
  83   1        nop_();             //TMR1L,TMR1H执行后需要一个nop
  84   1        /*
  85   1        (3)开启中断
  86   1        */
  87   1        PIR1 &= 0xF7;       //清中断标志位
  88   1        nop_();             //PIRx执行后需要一个nop
  89   1        PIE1 |= 0X08;       //允许Timer1中断
  90   1        /*
  91   1        (4)设置Timer中断优先级
  92   1        */  
  93   1        //IRQ_SET_PRIORITY(IRQ_TMR1); //如果选择Timer1中断为高优先级，打开此语句
  94   1        IRQ_ALL_ENABLE();   //使能中断
  95   1      
  96   1        /*
  97   1        (5)开启Timer
  98   1        */
  99   1        T1CON |= 0x01;    //开启Timer1
 100   1      }
