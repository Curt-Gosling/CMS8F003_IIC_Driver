 120          
 121          void IRQHandler_call(void){
 122   1        
 123   1        //定时触发系统
 124   1        if(++counter_2ms >= 2){
 125   2            counter_2ms = 0;
 126   2            flag_2ms = 1;
 127   2          if(++counter_4ms >= 2){
 128   3              counter_4ms = 0;
 129   3              flag_4ms = 1;
 130   3          }
 131   2          if(++counter_10ms >= 5){
 132   3              counter_10ms = 0;
 133   3              flag_10ms = 1;          
 134   3            if(++counter_100ms >= 10){
 135   4                counter_100ms = 0;
 136   4                flag_100ms = 1;           
 137   4              if(++counter_500ms >= 5){
 138   5                  counter_500ms = 0;
 139   5                  flag_500ms = 1;
 140   5                  if(++counter_10s >= 20){
 141   6                    counter_10s = 0;  //休眠专用
 142   6                    flag_10s = 1;
 143   6                  }
 144   5                  if(++counter_15s >= 30){
 145   6                    counter_15s = 0;
 146   6                    flag_15s = 1; 
 147   6                    if(delay01_5min > 0){
 148   7                      delay01_5min--;
 149   7                    }
 150   6                    if(delay02_5min > 0){
 151   7                      delay02_5min--;
 152   7                    }             
 153   6                  }           
 154   5                }
 155   4              }
 156   3            }
 157   2          }
 158   1      }
