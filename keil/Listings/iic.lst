  77          
  78          // IIC读写事务状态机
  79          void IIC_StateMachine_ISR(void)
  80          {
  81   1          switch(iic_ctx.Step){
  82   2              case 1: 
  83   2                  IICBUF = iic_ctx.DevAddr; //发设备地址+写
  84   2                  iic_ctx.Step = 2; 
  85   2                  break;
  86   2              case 2:  
  87   2                  IICBUF = iic_ctx.RegAddr; //发寄存器地址
  88   2                  iic_ctx.Step = 3;
  89   2                  break;
  90   2              // ========== 读流程分支 ==========
  91   2              case 3: 
  92   2                  if(iic_ctx.NeedNack){
  93   3                      IICCON2 |= 0x02; //RESTART
  94   3                      iic_ctx.Step = 4;
  95   3                  }
  96   2                  // ========== 写流程分支 ==========
  97   2                  else {
  98   3                      IICBUF = 0x30;  //发送数据
  99   3                      iic_ctx.Step = 8;
 100   3                  }
 101   2                  break;
 102   2              case 4: 
 103   2                  IICBUF = iic_ctx.DevAddr|0x01; //发设备地址+读
 104   2                  iic_ctx.Step = 5;
 105   2                  break;
 106   2              case 5: 
 107   2                  IICCON2 |= 0x08; //读取数据
 108   2                  iic_ctx.Step = 6;
 109   2                  break;
 110   2              case 6: 
 111   2                  IIC_RxData = IICBUF;  // 保存接收到的数据
 112   2                  IICCON2 |= 0x20;      // ACKDT = 1，即 NACK    
 113   2                  IICCON2 |= 0x10;      // ACKEN = 1，启动应答序列
 114   2                  iic_ctx.Step = 7;
 115   2                  break;
C51 COMPILER V9.60.7.0   IIC                                                               04/25/2026 16:57:27 PAGE 3   

 116   2              case 7:
 117   2                  IICCON2 |= 0x04; // STOP
 118   2                  iic_ctx.Step = 9;
 119   2                  break;
 120   2              case 8:
 121   2                  IICCON2 |= 0x04; //STOP
 122   2                  iic_ctx.Step = 9;
 123   2                  break;
 124   2              case 9:
 125   2                  IIC_Status = IIC_IDLE;
 126   2                  iic_ctx.Step = 0;
 127   2                  iic_ctx.NeedNack = 0;
 128   2                  break;
 129   2              default:
