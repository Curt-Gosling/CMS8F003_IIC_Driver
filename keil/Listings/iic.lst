 137          /***********************************************
 138          函数名称：IIC_Set_Master
 139          函数功能：IIC状态设置
 140          入口参数：无
 141          出口参数：无
 142          备注：
 143          ************************************************/
 144          void IIC_Set_Master()
 145          { 
 146   1        IIC_SDA_IO = 1;         //SDA及SCL为输入口使能IIC后自动为漏极开路
 147   1        IIC_SCL_IO = 1;         
 148   1        IICADD = 0x24;          //时钟=FSYS/(4*(IICADD+4)) 100khz
 149   1        IICSTAT = 0x00;         
 150   1        IICCON = 0x20;          //主控模式
 151   1        IICCON2 = 0x00;
 152   1      }
 153          
 154          void IIC_Config(void)
 155          {
 156   1        IICSEL = 0x00;  // IIC通讯口选择 SDA=P05, SCL=P04
 157   1        GPIO_ENABLE_INPUT(P0TRIS, GPIO_PIN_4);    //初始化P04为输入口
 158   1        GPIO_ENABLE_INPUT(P0TRIS, GPIO_PIN_5);    //初始化P05为输入口 
 159   1        IIC_Set_Master();
 160   1          // 开启IIC中断
 161   1          PIR2 &= 0xFD;         //清IICIF标志位
 162   1          nop_();
 163   1          PIE2 |= 0x02;         //使能IIC中断
 164   1          IRQ_ALL_ENABLE();     //使能中断
 165   1      }
