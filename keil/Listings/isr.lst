 169          /******************************************************************************
 170           ** \brief  IIC interrupt service function
 171           **
 172           ** \param [in]  none   
 173           **
 174           ** \return none
 175           ******************************************************************************/
 176          void IIC_IRQHandler(void)  interrupt IIC_VECTOR 
 177          {
C51 COMPILER V9.60.7.0   ISR                                                               04/25/2026 16:57:27 PAGE 4   

 178   1          // 时序动作完成后自动触发中断
 179   1          if(PIR2 & 0x02)     // 检查IIC中断
 180   1          {
 181   2              PIR2 &= 0xFD;   // 清IICIF标志位
 182   2              nop_(); 
 183   2              // 执行IIC事务状态机
 184   2              IIC_StateMachine_ISR();
 185   2          }
 186   1      }
