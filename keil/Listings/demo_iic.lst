 157          备注：
 158          ************************************************/
 159          unsigned char IIC_Read1Byte()
 160          {
 161   1          printf("IIC_Read1Byte\n");
 162   1          IICCON2 |= 0x08;
 163   1          if(IIC_WaitStatus() == FALSE) {
 164   2              printf("  -> Read timeout!\n");
 165   2              return 0xFF;  // 返回一个明显的错误值
 166   2          }
 167   1          printf("  -> Read OK, data=0x%02X\n", (int)IICBUF);
 168   1          return IICBUF;
 169   1      }
