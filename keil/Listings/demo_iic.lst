  93          
  94          /***********************************************
  95          函数名称：IIC_Start
  96          函数功能：硬件产生IIC启动信号
  97          入口参数：无
  98          出口参数：无
  99          备注：
 100          ************************************************/
 101          void IIC_Start()
 102          {
 103   1          printf("IIC_Start\n");
 104   1          IICCON2 |= 0x01;
 105   1          if(IIC_WaitStatus() == FALSE) {
 106   2              printf("  -> Start timeout!\n");
 107   2          }
 108   1      }
 109          
 110          void IIC_ReStart()
 111          {
 112   1        IICCON2 |= 0x02;              //重复启动条件使能位  
 113   1      
 114   1        IIC_WaitStatus();             //等待启动信号产生完成
 115   1      }
