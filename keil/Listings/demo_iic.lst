 139          ************************************************/
 140          void IIC_Write1Byte(unsigned char Rdata)
 141          {
 142   1          printf("Sending: 0x%02X\n", (int)Rdata);
 143   1          IICBUF = Rdata;
 144   1          if(IIC_WaitStatus() == FALSE) {
