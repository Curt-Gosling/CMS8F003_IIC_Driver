  76          /***********************************************
  77          函数名称：IIC_Set_Master
  78          函数功能：IIC状态设置
  79          入口参数：无
  80          出口参数：无
  81          备注：
  82          ************************************************/
  83          void IIC_Set_Master()
  84          { 
  85   1        IIC_SDA_IO = 1;         //SDA及SCL为输入口使能IIC后自动为漏极开路
  86   1        IIC_SCL_IO = 1;         
  87   1        IICADD = 0x24;          //时钟=FSYS/(4*(IICADD+4)) 100khz
  88   1        IICSTAT = 0x00;         
  89   1        IICCON = 0x20;          //主控模式
  90   1        IICCON2 = 0x00;
  91   1      }
