 176          备注：
 177          ************************************************/
C51 COMPILER V9.60.7.0   DEMO_IIC                                                          04/13/2026 21:10:58 PAGE 4   

 178          void IIC_Answer(unsigned char ack)
 179          {
 180   1         
 181   1        if(ack)                 //发送完成后是否发送应答
 182   1          IICCON2 |= 0x20;      //1不应答
 183   1        else
 184   1          IICCON2 &= 0xDF;      //0应答
 185   1        
 186   1        IICCON2 |= 0x01;        //启动应答，发送ACKDT数据位 
 187   1          
 188   1        IIC_WaitStatus();       //等待ACK发送完成
 189   1      }
 190          /***********************************************
 191          函数名称：IIC_WaitStatus
 192          函数功能：状态等待完成及返回
 193          入口参数：无
 194          出口参数：TRUE OR FALSE
 195          备注：
 196          ************************************************/
 197          unsigned char IIC_WaitStatus()
 198          {
 199   1        unsigned int t = 5000;
 200   1        
 201   1        while(0 == (PIR2&0x02))         //直到完成为止
 202   1        {
 203   2          if(0 == (--t))
 204   2          {
 205   3            IIC_Set_Master();           //超时重新初始化
 206   3            PIR2 &= 0xFD;               //清IICIF标志位
 207   3            nop_();                     //PIRx执行后需要一个nop
 208   3            return FALSE;     
 209   3          }
 210   2        }
 211   1        PIR2 &= 0xFD;                   //清IICIF标志位
 212   1        nop_();                         //PIRx执行后需要一个nop
 213   1        return TRUE;
 214   1      }
