 223          /****************************************************************************
 224           * 函数名：IIC_Read_Adress_Byte
 225           * 功能描述：读指定设备地址的一个Byte数据
 226           * 输入值：设备地址，寄存器地址
 227           * 返回值：读取的数据
 228           * ************************************************************************/
 229          unsigned char IIC_Read_Adress_Byte(unsigned char Write_Device_Adress, unsigned char Reg_Adress)
 230          {
 231   1          unsigned char Read_Device_Adress = Write_Device_Adress + 1;
 232   1          unsigned char Rdata;
 233   1          
 234   1          // 写寄存器地址
 235   1          IIC_Start();
 236   1          IIC_Write1Byte(Write_Device_Adress);// 发送设备地址+写
 237   1          IIC_Write1Byte(Reg_Adress);         // 发送寄存器地址
 238   1          // 重新启动读数据
 239   1          IIC_ReStart();                      // 重复启动条件使能位 
C51 COMPILER V9.60.7.0   DEMO_IIC                                                          04/13/2026 21:10:58 PAGE 5   

 240   1          IIC_Write1Byte(Read_Device_Adress); // 发送设备地址+读
 241   1          Rdata = IIC_Read1Byte();            // 读取数据
 242   1          IIC_Answer(1);                      // 发送NACK
 243   1          IIC_Stop();
 244   1          
 245   1          return Rdata;
 246   1      }
